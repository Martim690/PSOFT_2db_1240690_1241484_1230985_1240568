@startuml
autonumber
actor "Backoffice Operator/Admin" as Operator
participant "AircraftModelController" as Controller
participant "RegisterAircraftModelUseCase" as UseCase
participant "FileSystem (I/O)" as Disk
participant "AircraftModelRepository" as Repo

Operator -> Controller: POST /api/aircraft-models (multipart)
activate Controller

Controller -> UseCase: execute(dto, file)
activate UseCase

UseCase -> Repo: findByModelName()
Repo --> UseCase: Optional.empty

alt if file exists
    UseCase -> Disk: copy(file, path)
    Disk --> UseCase: success
end

UseCase -> Repo: save(model)
Repo --> UseCase: savedModel

UseCase --> Controller: AircraftModelResponse
deactivate UseCase

Controller --> Operator: 201 Created
deactivate Controller
@enduml