@startuml
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
hide empty methods
title AlSafe - Domain Model


' WP #0A - SYSTEM SETUP

package "User Aggregate" {
  class User <<aggregate root>> <<entity>> {
    username : String
    password : Password
  }
  enum Role {
    BACKOFFICE_OPERATOR
    ATCC
    MAINTENANCE_TECHNICIAN
    MAINTENANCE_SUPERVISOR
  }
  User "1" *-- "1..*" Role : has >
}

package "Manufacturer Aggregate" {
  class Manufacturer <<aggregate root>> <<entity>> {
    name : String
  }
}


' WP #1A & #1B - ENHANCED AIRCRAFT MANAGEMENT

package "Aircraft Model Aggregate" {
  class AircraftModel <<aggregate root>> <<entity>> {
    modelName : String
    fuelCapacity : int
    maximumRange : int
    cruisingSpeed : int
    technicalDiagramOrImage : String
  }
}

package "Aircraft Aggregate" {
  enum AircraftStatus {
    AVAILABLE
    IN_FLIGHT
    UNDER_MAINTENANCE
    INACTIVE
  }

  class Aircraft <<aggregate root>> <<entity>> {
    manufacturingDate : Date
    seatingCapacity : int
    totalFlightHours : double
    currentStatus : AircraftStatus
  }

  class RegistrationNumber <<value object>> {
    registrationNumber : String
  }

    Aircraft "1" *-- "1" RegistrationNumber : has >
  Aircraft "1" *-- "1" AircraftStatus : uses >
}


' WP #2A & #2B - ENHANCED AIRPORTS

package "Airport Aggregate" {
  enum AirportStatus {
    OPERATIONAL
    CLOSED
    UNDER_MAINTENANCE
  }

  class Airport <<aggregate root>> <<entity>> {
    name : String
    city : String
    country : String
    region : String
    timezone : String
    operationalHours : String
    photos : List<String>
    operationalStatus : AirportStatus
  }

  enum ContactType <<value object>> {
      PHONE
      EMAIL
      FAX
      RADIO
    }

  class ContactInfo <<value object>> {
      contactType : ContactType
      value : String
      department : String
  }

  class IATAcode <<value object>> {
    code : String
  }

  class Coordinates <<value object>> {
    latitude : double
    longitude : double
  }

  class RunwayInfo <<value object>> {
    name : String
    length : int
    orientation : String
  }

  class FacilityInfo <<value object>> {
    terminals : int
    gates : int
    services : List<String>
  }

  Airport "1" *-- "1" Coordinates : located at >
  Airport "1" *-- "1" IATAcode : has >
  Airport "1" *-- "1..*" RunwayInfo : has >
  Airport "1" *-- "1" AirportStatus : uses >
  Airport "1" *-- "1" FacilityInfo : provides >
  Airport "1" *-- "1..*" ContactInfo : has >
  ContactInfo "1" *-- "1" ContactType : of type >
}


' WP #3A - FLIGHT ROUTES

package "Route Aggregate" {
  class Route <<aggregate root>> <<entity>> {
    distance : double
    estimatedFlightTime : int
    isActive : boolean
  }
  class RouteID <<value object>> {
    routeId : String
  }

  class RouteRequirements <<value object>> {
    minimumRange : int
    minimumCapacity : int
  }
  Route "1" *-- "1" RouteRequirements : demands >
    Route "1" *-- "1" RouteID : has >
}


' WP #3B - FLIGHT SCHEDULING

package "Scheduled Flight Aggregate" {

  enum FlightStatus {
    SCHEDULED
    DELAYED
    CANCELED
    IN_FLIGHT
    COMPLETED
  }

  class ScheduledFlight <<aggregate root>> <<entity>> {
    scheduledDate : Date
    scheduledTime : String
    currentStatus : FlightStatus
  }

  class FlightNumber <<value object>> {
   flightNumber : String
  }

  ScheduledFlight "1" *-- "1" FlightNumber : has >
  ScheduledFlight "1" *-- "1" FlightStatus : uses >
}


' WP #4A & #4B - ENHANCED MAINTENANCE

package "Maintenance Template Aggregate" {
  enum TemplateType {
    INSPECTION
    SCHEDULED_MAINTENANCE
    OVERHAUL
    MODIFICATION
  }

  class MaintenanceTemplate <<aggregate root>> <<entity>> {
    templateName : String
    templateType : TemplateType
  }

  class Checklist <<value object>> {
    tasks : List<String>
  }

  MaintenanceTemplate "1" *-- "1" Checklist : defines >
  MaintenanceTemplate "1" *-- "1" TemplateType : uses >
}

package "Maintenance Record Aggregate" {
  enum ComponentType {
    ENGINE
    AIRFRAME
    AVIONICS
    INTERIOR
    EXTERIOR
  }

  class MaintenanceRecord <<aggregate root>> <<entity>> {
    description : String
    startDate : Date
    expectedDuration : int
    completionDate : Date
    maintenanceStatus : MaintenanceStatus
    completionNotes : String
    maintenanceComponent : ComponentType
    maintenanceCost : double
  }

  enum MaintenanceStatus {
   SCHEDULED,
   IN_PROGRESS,
   WAITING_PARTS,
   COMPLETED,
   CANCELED
 }

  MaintenanceRecord "1" *-- "1" ComponentType : uses >
  MaintenanceRecord "1" *-- "1" MaintenanceStatus : uses >
}


' RELAÇÕES GLOBAIS ENTRE AGGREGADOS

AircraftModel "*" --> "1" Manufacturer : built by >

Aircraft "*" --> "1" AircraftModel : is of type >
Airport "*" --> "*" AircraftModel : certifies >

Route "*" --> "1" Airport : departs from (origin) >
Route "*" --> "1" Airport : arrives at (destination) >

ScheduledFlight "*" --> "1" Route : follows >
ScheduledFlight "*" --> "1" Aircraft : operated by >

MaintenanceTemplate "*" --> "*" AircraftModel : applicable to >
MaintenanceRecord "*" --> "1" Aircraft : performed on >
MaintenanceRecord "*" --> "1" MaintenanceTemplate : based on >

@enduml