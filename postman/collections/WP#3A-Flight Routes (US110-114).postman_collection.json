    {
      "name": "US110 - Criar rota",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 201 Created\", () => {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Has routeId\", () => {\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body.routeId).to.be.a('string');\r",
              "    pm.environment.set(\"routeId\", body.routeId);\r",
              "});\r",
              "\r",
              "pm.test(\"Route is active\", () => {\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body.active).to.be.true;\r",
              "});\r",
              "\r",
              "pm.test(\"Has HATEOAS links\", () => {\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body._links).to.have.property('self');\r",
              "    pm.expect(body._links).to.have.property('history');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
