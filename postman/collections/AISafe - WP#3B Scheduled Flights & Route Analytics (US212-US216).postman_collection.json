    {
      "name": "US214 - Rotas ativas ordenadas",
      "item": [
        {
          "name": "Ordenado por popularidade",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code é 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test(\"Resposta é um array\", function () {",
                  "    pm.expect(body).to.be.an(\"array\");",
                  "});",
                  "",
                  "pm.test(\"Todas as rotas estão ativas\", function () {",
                  "    body.forEach(r => pm.expect(r.active).to.be.true);",
                  "});",
                  "",
                  "pm.test(\"Ordenado de forma decrescente por usageCount\", function () {",
                  "    for (let i = 1; i < body.length; i++) {",
                  "        pm.expect(body[i - 1].usageCount).to.be.at.least(body[i].usageCount);",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"Cada rota tem routeId, distanceKm e usageCount\", function () {",
                  "    body.forEach(r => {",
                  "        pm.expect(r.routeId).to.exist;",
                  "        pm.expect(r.distanceKm).to.be.a(\"number\");",
                  "        pm.expect(r.usageCount).to.be.a(\"number\");",
                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/routes/active/sorted?sortBy=popularity",
              "host": [
