    {
      "name": "US216 - Rotas alternativas",
      "item": [
        {
          "name": "Sucesso - rotas diretas e com escala",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code é 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test(\"originAirport e destinationAirport correspondem ao pedido\", function () {",
                  "    pm.expect(body.originAirport).to.eql(pm.environment.get(\"originIata\"));",
                  "    pm.expect(body.destinationAirport).to.eql(pm.environment.get(\"destinationIata\"));",
                  "});",
                  "",
                  "pm.test(\"directRoutes e oneStopRoutes existem como arrays\", function () {",
                  "    pm.expect(body.directRoutes).to.be.an(\"array\");",
                  "    pm.expect(body.oneStopRoutes).to.be.an(\"array\");",
                  "});",
                  "",
                  "pm.test(\"Rotas diretas, se existirem, ligam origin a destination\", function () {",
                  "    body.directRoutes.forEach(r => {",
                  "        pm.expect(r.originIataCode).to.eql(pm.environment.get(\"originIata\"));",
                  "        pm.expect(r.destinationIataCode).to.eql(pm.environment.get(\"destinationIata\"));",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"Cadeias com escala estão coerentes (aeroporto de ligação correto)\", function () {",
                  "    body.oneStopRoutes.forEach(chain => {",
                  "        pm.expect(chain.firstLeg.destinationIataCode).to.eql(chain.connectionAirport);",
                  "        pm.expect(chain.secondLeg.originIataCode).to.eql(chain.connectionAirport);",
                  "        pm.expect(chain.firstLeg.originIataCode).to.eql(pm.environment.get(\"originIata\"));",
                  "        pm.expect(chain.secondLeg.destinationIataCode).to.eql(pm.environment.get(\"destinationIata\"));",
                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/routes/alternatives?origin={{originIata}}&destination={{destinationIata}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "routes",
                "alternatives"
              ],
              "query": [
                {
                  "key": "origin",
                  "value": "{{originIata}}"
                },
                {
                  "key": "destination",
                  "value": "{{destinationIata}}"
                }
              ]
            }
          },
          "response": []
        },
