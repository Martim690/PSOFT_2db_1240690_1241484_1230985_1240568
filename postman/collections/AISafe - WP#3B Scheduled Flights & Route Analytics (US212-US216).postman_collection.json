      "name": "US215 - Distância total da rede",
      "item": [
        {
          "name": "Sucesso - calcula distância total",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code é 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test(\"totalDistanceKm é um número >= 0\", function () {",
                  "    pm.expect(body.totalDistanceKm).to.be.a(\"number\");",
                  "    pm.expect(body.totalDistanceKm).to.be.at.least(0);",
                  "});",
                  "",
                  "pm.test(\"activeRouteCount é um inteiro >= 0\", function () {",
                  "    pm.expect(body.activeRouteCount).to.be.a(\"number\");",
                  "    pm.expect(body.activeRouteCount).to.be.at.least(0);",
                  "});",
                  "",
                  "pm.test(\"Se não há rotas ativas, distância total é 0\", function () {",
                  "    if (body.activeRouteCount === 0) {",
                  "        pm.expect(body.totalDistanceKm).to.eql(0);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/routes/total-distance",
              "host": [
